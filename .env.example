DEPLOY_HOST=user@server
DEPLOY_PATH=/var/www/portmgmt
REPORT_TZ=Asia/Shanghai
OBSIDIAN_VAULT_PATH=
PORTMGMT_SUPPLEMENTAL_DIR=

# Optional static GitHub Pages password gate.
# Set PORTMGMT_PASSWORD as a GitHub Actions Secret, not a Variable.
PORTMGMT_PASSWORD=
PORTMGMT_REMEMBER_DAYS=45
LLM_PROVIDER=qwen
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
QWEN_REASONING_EFFORT=high
LLM_ENABLED=false
